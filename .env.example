# RootBot - Environment Variables Example
# Bu dosyayı .env olarak kopyalayıp kendi bilgilerinizi girin

# ===== Telegram Bot Configuration =====
# BotFather'dan aldığınız bot token
# Nasıl alınır: https://t.me/BotFather -> /newbot
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram kullanıcı ID'niz (sadece siz erişebilir)
# Nasıl bulunur: https://t.me/userinfobot
ALLOWED_USER_ID=987654321

# ===== Application Settings =====
# Çalışma ortamı: production veya development
NODE_ENV=production

# Log seviyesi: error, warn, info, debug
# Önerilen: info (production), debug (development)
LOG_LEVEL=info

# ===== Opsiyonel Ayarlar =====
# Port (gerekirse değiştirin)
# PORT=3000

# Performans izleme aralığı (ms)
# PERFORMANCE_INTERVAL=5000

# Screenshot kalitesi (0-100)
# SCREENSHOT_QUALITY=90

# Video kayıt FPS
# RECORDING_FPS=30
